{\pard \ql \f0 \sa180 \li0 \fi0 \outlinelevel2 \b \fs28 JSON File Format\par}
{\pard \ql \f0 \sa180 \li0 \fi0 {\f1 vmClasses.json} is a JSON array. Each object represents one VM class.\par}
{\pard \ql \f0 \sa180 \li0 \fi0 \f1 [\line
  \{\line
    "name": "best-effort-2xlarge",\line
    "cpuCount": 8,\line
    "cpuCommitment": "bestEffort",\line
    "memoryMB": 16384,\line
    "memoryCommitment": "bestEffort"\line
  \},\line
  \{\line
    "name": "guaranteed-gpu-class",\line
    "description": "Reserved class with A100 GPU",\line
    "cpuCount": 16,\line
    "cpuCommitment": "guaranteed",\line
    "memoryMB": 65536,\line
    "memoryCommitment": "guaranteed",\line
    "vgpuDevices": [\line
      \{\line
        "profileNames": ["nvidia-a100-40c"]\line
      \}\line
    ]\line
  \}\line
]\par}
